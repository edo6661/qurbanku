    super.key,
    required this.savingId,
    required this.namaPengkurban,
    required this.targetName,
  });
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text(
          'Setoran: $namaPengkurban',
          style: const TextStyle(fontSize: 16),
