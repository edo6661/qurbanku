                                  context,
                                  MaterialPageRoute(
                                    builder: (_) => const RegisterPage(),
                                  ),
                                );
                              },
                        child: const Text('Belum punya akun? Daftar di sini'),
                      ),
                      TextButton(
                        onPressed: () =>
                            DatabaseSeeder.seedInitialData(context),
                        child: const Text(
                          'Jalankan Seeder (Buat Data Dummy)',
                          style: TextStyle(color: Colors.grey),
