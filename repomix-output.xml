      'status': status.name,
      'nama_pengkurban': namaPengkurban,
      'bin_binti': binBinti,
    };
  }
  static SavingStatus _parseStatus(String? statusStr) {
    if (statusStr == 'completed') return SavingStatus.completed;
    return SavingStatus.active;
